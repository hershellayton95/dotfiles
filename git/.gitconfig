[core]
	editor = nvim
	autocrlf = false
[credential]
	helper = store

[includeIf "gitdir:~/workspace/personal/**"]
  path = ~/.config/git/.gitconfig-personal

[includeIf "gitdir:~/dotfiles/**"]
  path = ~/.config/git/.gitconfig-personal

[includeIf "gitdir:~/workspace/work/mobilize/**"]
  path = ~/.config/git/.gitconfig-mobilize-work

[includeIf "gitdir:~/workspace/work/gdclouders/**"]
  path = ~/.config/git/.gitconfig-gdclouders-work
